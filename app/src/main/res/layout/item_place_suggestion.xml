<?xml version="1.0" encoding="utf-8"?>
<!--
    item_place_suggestion.xml
    Card shown in the horizontal suggestions RecyclerView.
    Shows emoji, place name, type, and distance from route.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/suggestion_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Emoji icon -->
        <TextView
            android:id="@+id/tvEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="26sp"
            android:layout_marginBottom="6dp" />

        <!-- Place name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Place Name"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="3dp" />

        <!-- Type tag -->
        <TextView
            android:id="@+id/tvType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restaurant"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="6dp" />

        <!-- Distance from route -->
        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200 m from route"
            android:textColor="@color/primary_blue"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_medium" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
